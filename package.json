    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vercel": "latest",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
