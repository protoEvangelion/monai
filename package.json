    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.545.0",
    "nitro": "^3.0.260415-beta",
    "openai": "^6.34.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
